---
const { title = "Warning" } = Astro.props;
---

<div role="alert" class="flex flex-col alert bg-[#2c2e2d] p-5 max-sm:p-2 text-[18px]">
    <div class="text-2xl font-bold font-kode text-yellow-400">{ title }</div>
    <div class="text-neutral-300 bg-[#2c2e2d]">
        <slot />
    </div>
</div>

<style is:global>
.alert
{
    ul, ol
    {
        background-color: #2c2e2d;
    }
}
</style>